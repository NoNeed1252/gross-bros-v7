{
  "version": 2,
  "cleanUrls": true,
  "rewrites": [
    { "source": "/api/chat", "destination": "/api/chat.js" },
    { "source": "/api/xaman", "destination": "/api/xaman.js" },
    { "source": "/api/fusion-gate", "destination": "/api/fusion-gate.js" },
    { "source": "/api/callback", "destination": "/api/callback.js" }
  ],
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        { "key": "Cache-Control", "value": "no-store, max-age=0, must-revalidate" },
        { "key": "Pragma", "value": "no-cache" },
        { "key": "Expires", "value": "0" }
      ]
    }
  ]
}